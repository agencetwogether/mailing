{
    "name": "agencetwogether/mailing",
    "description": "Implement subscribing to mailing directly in Filament App",
    "keywords": [
        "agencetwogether",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "mailing"
    ],
    "homepage": "https://github.com/agencetwogether/mailing",
    "support": {
        "issues": "https://github.com/agencetwogether/mailing/issues",
        "source": "https://github.com/agencetwogether/mailing"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Max",
            "email": "contact@agencetwogether.fr",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0",
        "filament/spatie-laravel-settings-plugin": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Agencetwogether\\Mailing\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Agencetwogether\\Mailing\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse --memory-limit 1G",
        "lint": "pint",
        "test": "pest",
        "test:lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Agencetwogether\\Mailing\\MailingServiceProvider"
            ],
            "aliases": {
                "Mailing": "Agencetwogether\\Mailing\\Facades\\Mailing"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
